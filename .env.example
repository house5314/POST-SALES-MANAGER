# (선택) 운영 배포에서 URL ?demo=1 시연을 막을 때 true
# NEXT_PUBLIC_DEMO_DISABLED=true

# Maps > Application 의 Client ID (X-NCP-APIGW-API-KEY-ID). Access Key ID(ncp_iam_...) 아님.
# 스크립트 URL 쿼리는 코드에서 ncpKeyId 로 붙습니다(최신 공식 문서 기준).
# Client Secret 은 브라우저·NEXT_PUBLIC_* 에 넣지 마세요.
NEXT_PUBLIC_NAVER_CLIENT_ID=

# 소상공인365 iframe(클라이언트). 포털 URL: …/openApi/detail | storSttus | slsIdex
NEXT_PUBLIC_SBIZ_CERT_KEY=
NEXT_PUBLIC_SBIZ_CERT_DETAIL=
NEXT_PUBLIC_SBIZ_CERT_STOR_STTUS=
NEXT_PUBLIC_SBIZ_CERT_SLS_IDEX=
# (선택) 예전 이름 호환
NEXT_PUBLIC_SBIZ_OPENAPI_CERT_DETAIL=
NEXT_PUBLIC_SBIZ_OPENAPI_CERT_STOR_STTUS=
NEXT_PUBLIC_SBIZ_OPENAPI_CERT_SLS_IDEX=

# Google Generative AI (서버 전용·선택). `/api/ai/assist` 보조 응답용. 브라우저에 노출 금지.
GOOGLE_GENERATIVE_AI_API_KEY=
# (선택) 내부망·DMZ 프록시가 Google Generative Language API 호환 엔드포인트를 중계할 때 URL 접두.
# 기본: https://generativelanguage.googleapis.com/v1beta — 상세는 docs/ai-internal-network.md
GOOGLE_GENERATIVE_AI_BASE_URL=
# (선택) 모델 ID. 미설정 시 gemini-2.0-flash
GOOGLE_GENERATIVE_AI_MODEL=
# (선택) 샘플링 temperature. 미설정 시 0.2 — 코드가 0.2 초과값은 사용하지 않음(할루시네이션 억제)
GOOGLE_GENERATIVE_AI_TEMPERATURE=

# 공공데이터포털 serviceKey(서버 라우트 전용). 상가(B553077)·행정표준코드·단지 API 등 apis.data.go.kr
PUBLIC_DATA_API_KEY=

# 소상공인365 certKey(서버 전용·선택). 클라이언트 iframe에는 위 NEXT_PUBLIC_* 필요.
SBIZ_OPENAPI_CERT_DETAIL=
SBIZ_OPENAPI_CERT_STOR_STTUS=
SBIZ_OPENAPI_CERT_SLS_IDEX=
